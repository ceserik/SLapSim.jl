{
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "latex": false
    },
    "workbench.editor.enablePreview": true,
    "workbench.settings.applyToAllProfiles": [
        "workbench.editor.enablePreview",
        "editor.minimap.enabled"
    ],
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt"
    ],
    "julia.symbolCacheDownload": true,
    "editor.minimap.enabled": false,
    "window.newWindowProfile": "Default",
    "julia.execution.inlineResultsForCellEvaluation": true,
    "julia.execution.resultType": "inline, errors in REPL",
    "julia.debuggerDefaultCompiled": [    
        "ALL_MODULES_EXCEPT_MAIN",      
    ],
    "window.autoDetectColorScheme": true,
    "workbench.preferredDarkColorTheme": "Dark Modern",
    "workbench.preferredLightColorTheme": "Visual Studio Light",
   // "julia.environmentPath": "/home/Riso/.julia/dev/SLapSim/src",
    "julia.environmentPath": "/home/Riso/.julia/dev/SLapSim",
    "latex-workshop.latex.recipes": [
    {
        "name": "lualatex",
        "tools": ["lualatex", "bibtex", "lualatex", "lualatex"]
    }
],
"latex-workshop.latex.tools": [
    {
        "name": "lualatex",
        "command": "lualatex",
        "args": [
            "-synctex=1",
            "-interaction=nonstopmode",
            "-file-line-error",
            "%DOC%"
        ]
    },
    {
        "name": "bibtex",
        "command": "bibtex",
        "args": ["%DOCFILE%"]
    }
],
"latex-workshop.latex.recipe.default": "lualatex",
"latex-workshop.synctex.afterBuild.enabled": "true",
}